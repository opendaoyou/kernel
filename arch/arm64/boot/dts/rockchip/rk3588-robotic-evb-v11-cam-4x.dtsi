/ {
	vcc_mipicsi1: vcc-mipicsi1-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc_mipicsi1";
		gpio = <&i2c4_nca9539_gpio 8 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		enable-active-high;
	};

	vcc_mipidcphy0: vcc-mipidcphy0-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc_mipidcphy0";
		gpio = <&i2c4_nca9539_gpio 5 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		enable-active-high;
	};

	vcc_mipidcphy1: vcc-mipidcphy1-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc_mipidcphy1";
		gpio = <&i2c4_nca9539_gpio 6 GPIO_ACTIVE_HIGH>;
		regulator-boot-on;
		enable-active-high;
	};
};

&csi2_dcphy0 {
	status = "okay";
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;
			csidcphy0_in_imx415: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&imx415_out1>;
				data-lanes = <1 2 3 4>;
			};
			csidcphy0_in_imx586: endpoint@2 {
				reg = <2>;
				remote-endpoint = <&imx586_out1>;
				data-lanes = <1 2 3 4>;
			};
		};
		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			csidcphy0_out: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&mipi0_csi2_input>;
			};
		};
	};
};

&csi2_dcphy1 {
	status = "okay";
	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			csidcphy1_in_imx415: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&imx415_out2>;
				data-lanes = <1 2 3 4>;
			};
			csidcphy1_in_imx586: endpoint@2 {
				reg = <2>;
				remote-endpoint = <&imx586_out2>;
				data-lanes = <1 2 3 4>;
			};
		};
		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			csidcphy1_out: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&mipi1_csi2_input>;
			};
		};
	};
};

&csi2_dphy1_hw {
	status = "okay";
};

