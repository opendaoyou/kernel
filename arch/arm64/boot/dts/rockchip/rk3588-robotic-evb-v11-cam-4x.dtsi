&i2c3 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c3m0_xfer>;
	status = "okay";

	imx415_4: imx415-4@1a {
		compatible = "sony,imx415";
		reg = <0x1a>;
		clocks = <&cru CLK_MIPI_CAMARAOUT_M4>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		pinctrl-0 = <&mipim0_camera4_clk>;
		power-domains = <&power RK3588_PD_VI>;
		pwdn-gpios = <&i2c4_nca9539_gpio 3 GPIO_ACTIVE_HIGH>;
		avdd-supply = <&vcc_mipicsi1>;
		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "CMK-OT2022-PX1";
		rockchip,camera-module-lens-name = "IR0147-50IRC-8M-F20";
		port {
			imx415_out4: endpoint {
				remote-endpoint = <&csidphy4_in_imx415>;
				data-lanes = <1 2>;
			};
		};
	};

	imx415_5: imx415-5@1a {
		compatible = "sony,imx415";
		reg = <0x1a>;
		clocks = <&cru CLK_MIPI_CAMARAOUT_M4>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		pinctrl-0 = <&mipim0_camera4_clk>;
		power-domains = <&power RK3588_PD_VI>;
		pwdn-gpios = <&i2c4_nca9539_gpio 4 GPIO_ACTIVE_HIGH>;
		avdd-supply = <&vcc_mipicsi1>;
		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "CMK-OT2022-PX1";
		rockchip,camera-module-lens-name = "IR0147-50IRC-8M-F20";
		port {
			imx415_out5: endpoint {
				remote-endpoint = <&csidphy5_in_imx415>;
				data-lanes = <3 4>;
			};
		};
	};
};

&i2c4 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c4m1_xfer>;
	status = "okay";

	imx415_1: imx415-1@1a {
		compatible = "sony,imx415";
		reg = <0x1a>;
		clocks = <&cru CLK_MIPI_CAMARAOUT_M1>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		pinctrl-0 = <&mipim0_camera1_clk>;
		power-domains = <&power RK3588_PD_VI>;
		pwdn-gpios = <&i2c4_nca9539_gpio 0 GPIO_ACTIVE_HIGH>;
		avdd-supply = <&vcc_mipidcphy0>;
		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "CMK-OT2022-PX1";
		rockchip,camera-module-lens-name = "IR0147-50IRC-8M-F20";
		port {
			imx415_out1: endpoint {
				remote-endpoint = <&csidcphy0_in_imx415>;
				data-lanes = <1 2 3 4>;
			};
		};
	};

	imx586_1: imx586-1@1a {
		compatible = "sony,imx586";
		reg = <0x1a>;
		clocks = <&cru CLK_MIPI_CAMARAOUT_M1>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		pinctrl-0 = <&mipim0_camera1_clk>;
		power-domains = <&power RK3588_PD_VI>;
		pwdn-gpios = <&i2c4_nca9539_gpio 0 GPIO_ACTIVE_HIGH>;
		avdd-supply = <&vcc_mipidcphy0>;
		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "default";
		rockchip,camera-module-lens-name = "default";
		port {
			imx586_out1: endpoint {
				remote-endpoint = <&csidcphy0_in_imx586>;
				data-lanes = <1 2 3 4>;
			};
		};
	};
};

