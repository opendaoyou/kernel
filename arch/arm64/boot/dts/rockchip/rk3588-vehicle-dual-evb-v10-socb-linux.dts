/dts-v1/;

#include "rk3588-vehicle-dual-evb-v10-socb.dtsi"

#include "rk3588-vehicle-dual-evb-v10-socb-mcu-io-expander.dtsi"
#include "rk3588-vehicle-dual-evb-v10-socb-maxim-max96712-dphy0-ox03j10.dtsi"
#include "rk3588-vehicle-dual-evb-v10-socb-maxim-max96712-dphy3-ox03j10.dtsi"
#include "rk3588-vehicle-dual-evb-v10-socb-serdes-mfd-display-maxim.dtsi"
#include "rk3588-linux.dtsi"

/ {
	model = "Rockchip RK3588 VEHICLE DUAL EVB V10 SOCB LINUX Board";
	compatible = "rockchip,rk3588-vehicle-dual-evb-v10-socb-linux", "rockchip,rk3588";

	chosen: chosen {
		bootargs = "earlycon=uart8250,mmio32,0xfeb50000 console=ttyFIQ0 irqchip.gicv3_pseudo_nmi=0 root=PARTUUID=614e0000-0000 rw rootwait rcupdate.rcu_expedited=1 rcu_nocbs=all";
	};

	adc_pwr_vcc3v3_buck: adc_pwr_vcc3v3-buck {
		compatible = "regulator-fixed";
		regulator-name = "adc_pwr_vcc3v3_buck";
		regulator-boot-on;
		regulator-always-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		enable-active-high;
		gpio = <&gpio_mcu_rockchip_socb MCU_ADC_PWDN_L GPIO_ACTIVE_LOW>;
		vin-supply = <&vcc_3v3_s3>;
		regulator-state-mem {
			regulator-off-in-suspend;
			regulator-suspend-microvolt = <3300000>;
		};
	};

	a2b_pwr_vcc3v3_buck: a2b_pwr_vcc3v3-buck {
		compatible = "regulator-fixed";
