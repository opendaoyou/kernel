/dts-v1/;
#include "rk3326.dtsi"
#include "rk3326-linux.dtsi"	
#include "rk3326-common.dtsi"

/ {
	model = "daoyou rk3326 Appolo for linux";
	compatible = "daoyou,rk3326-appolo", "rockchip,rk3326";

	chosen {
		bootargs = "earlycon=uart8250,mmio32,0xff160000 console=tty1 rw root=PARTUUID=614e0000-0000 rootfstype=ext4 rootwait";
    };

	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 2>;
		io-channel-names = "buttons";
		poll-interval = <100>;
		keyup-threshold-microvolt = <1800000>;

		esc-key {
			linux,code = <KEY_BACK>;
			label = "back";
			press-threshold-microvolt = <1310000>;
		};

		menu-key {
			linux,code = <KEY_MENU>;
			label = "menu";
			press-threshold-microvolt = <987000>;
		};

		vol-down-key {
			linux,code = <KEY_VOLUMEDOWN>;
			label = "volume down";
			press-threshold-microvolt = <300000>;
		};

		vol-up-key {
			linux,code = <KEY_VOLUMEUP>;
			label = "volume up";
			press-threshold-microvolt = <17000>;
		};
	};

	gpio-keys {
		status = "okay";
		compatible = "gpio-keys";

		swl {
			gpios = <&gpio0 0x0d 0x01>;
			linux,code = <KEY_PLAYPAUSE>;
			label = "play";
			debounce-interval = <5>;
		};

		swr {
			gpios = <&gpio0 0x0f 0x01>;
			linux,code = <KEY_VOLUMEDOWN>;
			label = "volume down";
			debounce-interval = <5>;
		};
	};

	/*
 *  keys layout:
 *
 *     __________________
 *    |                 |
 *    |            pwr  |
 *    |      LCD   swl  | 
 *    |            swr  |
 *    |_________________|
 *
 *  adc:    [ esc ]
 *
 *   [ memu ]     [ vol- ]
 *
 *         [ vol+ ]
 *
 */
 	wireless-wlan {
		compatible = "wlan-platdata";
		wifi_chip_type = "rtl8723ds";
		WIFI,host_wake_irq = <&gpio0 RK_PB2 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};

&dsi {
	status = "okay";

	panel@0 {
		compatible = "simple-panel-dsi";
		reg = <0>;
		backlight = <&backlight>;
		power-supply = <&vcc_lcd>;
		enable-gpios = <&gpio3 RK_PB5 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio3 RK_PC4 GPIO_ACTIVE_LOW>;
		prepare-delay-ms = <20>;
		reset-delay-ms = <50>;
		init-delay-ms = <120>;
		enable-delay-ms = <50>;
		disable-delay-ms = <20>;
		unprepare-delay-ms = <20>;

		width-mm = <68>;
		height-mm = <121>;

		dsi,flags = <(MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST |
			      MIPI_DSI_MODE_LPM | MIPI_DSI_MODE_NO_EOT_PACKET)>;
		dsi,format = <MIPI_DSI_FMT_RGB888>;
		dsi,lanes = <2>;

		panel-init-sequence = [39 00 06 ff 77 01 00 00 13 15 00 02 ef 08 39 00 06 ff 77 01 00 00 10 39 00 03 c0 4f 00 39 00 03 c1 10 0c 39 00 03 c2 01 14 15 00 02 cc 10 39 00 11 b0 0a 18 1e 12 16 0c 0e 0d 0c 29 06 14 13 29 33 1c 39 00 11 b1 0a 19 21 0a 0c 00 0c 03 03 23 01 0e 0c 27 2b 1c 39 00 06 ff 77 01 00 00 11 15 00 02 b0 5d 15 00 02 b1 4b 15 00 02 b2 84 15 00 02 b3 80 15 00 02 b5 4d 15 00 02 b7 85 15 00 02 b8 20 15 00 02 c1 78 15 00 02 c2 78 15 00 02 d0 88 39 00 04 e0 00 00 02 39 00 0c e1 06 a0 08 a0 05 a0 07 a0 00 44 44 39 00 0d e2 20 20 44 44 96 a0 00 00 96 a0 00 00 39 00 05 e3 00 00 22 22 39 00 03 e4 44 44 39 00 11 e5 0d 91 0a a0 0f 93 0a a0 09 8d 0a a0 0b 8f 0a a0 39 00 05 e6 00 00 22 22 39 00 03 e7 44 44 39 00 11 e8 0c 90 0a a0 0e 92 0a a0 08 8c 0a a0 0a 8e 0a a0 39 00 03 e9 36 00 39 00 07 eb 00 01 e4 e4 88 40 39 00 11 ed ff 45 67 fa 01 2b cf ff ff fc b2 10 af 76 54 ff 39 00 07 ef 10 0d 04 08 3f 1f 05 78 01 11 15 00 02 35 00 05 14 01 29];
		panel-exit-sequence = <0x5000128 0x5780110>;

		display-timings {
			native-mode = <&timing0>;

			timing0: timing0 {
				clock-frequency = <33000000>;
				hactive = <480>;
				vactive = <640>;
				hback-porch = <160>;
				hfront-porch = <160>;
				hsync-len = <8>;	
				vback-porch = <20>;
				vfront-porch = <20>;
				vsync-len = <8>;
				hsync-active = <0>;
				vsync-active = <0>;
				de-active = <0>;
				pixelclk-active = <0>;
			};
		};

		ports {
			#address-cells = <1>;
			#size-cells = <0>;

			port@0 {
				reg = <0>;
				panel_in_dsi: endpoint {
					remote-endpoint = <&dsi_out_panel>;
				};
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			dsi_out_panel: endpoint {
				remote-endpoint = <&panel_in_dsi>;
			};
		};
	};
};

&i2c0 {
	
	battery {
		compatible = "rk817,battery";
		ocv_table = <3400 3649 3680 3702 3729 3750 3773 3791 3809 3831 3858 3893 3951 3991 4053 4100 4154 4211 4268 4326 4379>;
		design_capacity = <1510>;
		design_qmax = <1530>;
		bat_res = <110>;
		sleep_enter_current = <30>;
		sleep_exit_current = <30>;
		sleep_filter_current = <20>;
		power_off_thresd = <3000>;
		zero_algorithm_vol = <3000>;
		max_soc_offset = <60>;
		monitor_sec = <5>;
		sample_res = <26>;
		virtual_power = <0>;
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <400000>;
	i2c-scl-rising-time-ns = <275>;
	i2c-scl-falling-time-ns = <16>;

	silead@40 {
		status = "okay";
		compatible = "silead,gsl1691";
		reg = <0x40>;
		irq_gpio = <&gpio0 RK_PA5 8>;
		rst_gpio = <&gpio0 RK_PB4 0>;
	};

    zinitix@20 {
		status = "okay";
		compatible = "zinitix,bt541_ts_device";
		reg = <0x20>;
		zinitix,reset-gpio = <&gpio0 RK_PB4 0>;
		zinitix,irq-gpio = <&gpio0 RK_PA5 8>;
		zinitix,x_resolution = <0x1e0>;
		zinitix,y_resolution = <0x280>;
		zinitix,page_size = <0x80>;
		zinitix,orientation = <0x00>;
		zinitix,pname = "SM-G5308W";
	};
};

&i2c2 {
	status = "okay";
};



&vip_mmu {
	status = "okay";
};

/* Panfrost driver */
&gpu {
	mali-supply = <&vdd_logic>;
    interrupts = <GIC_SPI 47 IRQ_TYPE_LEVEL_HIGH>,
                 <GIC_SPI 46 IRQ_TYPE_LEVEL_HIGH>,
                 <GIC_SPI 45 IRQ_TYPE_LEVEL_HIGH>;

    interrupt-names = "job", "mmu", "gpu";
    status = "okay";
};